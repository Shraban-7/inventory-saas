APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Non-local defaults: LOG_CHANNEL=stderr (JSON), production LOG_LEVEL=warning when unset.
# REDIS_QUEUE_RETRY_AFTER=360

# Cold archive exports (canonical DB rows are never deleted by archival jobs).
# ARCHIVE_DISK=s3
# ARCHIVE_PATH_PREFIX=archives
# ARCHIVE_RETENTION_YEARS=5
# ARCHIVE_SCHEMA_VERSION=1
# ARCHIVE_CHUNK_SIZE=500
# ARCHIVE_EXPORT_TIMEOUT=300
# ARCHIVE_EXPORT_CLAIM_GRACE=30
# True S3 Object Lock / bucket versioning is infrastructure-required; app metadata is only a hint.

# Queue worker heartbeat / readiness (DB probe uses PDO::ATTR_TIMEOUT=5 from database config).
# HEALTH_HEARTBEAT_CACHE_STORE=
# HEALTH_HEARTBEAT_IDLE_TTL=45
# HEALTH_HEARTBEAT_BUSY_GRACE=30
# HEALTH_HEARTBEAT_WORKER_TIMEOUT=90
# HEALTH_HEARTBEAT_THROTTLE=5

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=inventory_saas
DB_USERNAME=root
DB_PASSWORD=

# Write path (ProxySQL in Docker compose). Falls back to DB_HOST when unset.
# DB_WRITE_HOST=127.0.0.1
# DB_WRITE_PORT=3306

# Optional journal/reporting replica. Omit DB_READ_HOST to fall back to DB_WRITE_HOST/DB_HOST.
# DB_READ_CONNECTION=mysql
# DB_READ_HOST=127.0.0.1
# DB_READ_PORT=3306
# DB_READ_DATABASE=inventory_saas
# DB_READ_USERNAME=root
# DB_READ_PASSWORD=

# ProxySQL mysql_users.max_connections per app account (compose wires this; not inert).
DB_MAX_CONNECTIONS=50

# Docker Compose MySQL/ProxySQL stack credentials (DEV-ONLY defaults in compose.yaml).
# Prefer these over DB_* so a local root .env cannot break the ProxySQL app user.
# MYSQL_DATABASE=inventory_saas
# MYSQL_USER=inventory
# MYSQL_PASSWORD=inventory_dev_only_change_me
# MYSQL_ROOT_PASSWORD=root_dev_only_change_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Deployed environments should use redis. phpunit.xml keeps QUEUE_CONNECTION=sync for tests.
QUEUE_CONNECTION=redis
QUEUE_AFTER_COMMIT=true
ACCOUNTING_ROLLUP_LOOKBACK_DAYS=7
REPORT_JOB_TTL_HOURS=168

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CONNECT_TIMEOUT=2
REDIS_READ_TIMEOUT=2

# Horizon (Linux/Docker). Requires ext-pcntl + ext-posix at runtime.
HORIZON_PATH=horizon
# HORIZON_PREFIX=
# HORIZON_NAME=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
